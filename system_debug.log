# QUIC throughput
# iperf3 -c 10.0.1.50 -p 5201 --udp -t 30

# ============================================================
# SECTION 8: Log Rotation Policy (นโยบายหมุนเวียน Log)
# ============================================================

# Log files:
#   - /var/log/ndid/system_debug.log    ( maxSize: 100MB, keep: 30 days)
#   - /var/log/ndid/audit.log          ( maxSize: 50MB,  keep: 365 days)
#   - /var/log/ndid/security.log       ( maxSize: 50MB,  keep: 365 days)
#   - /var/log/ndid/performance.log    ( maxSize: 200MB, keep: 7 days)

# Rotation command:
# logrotate -f /etc/logrotate.d/ndid-system

# Manual cleanup:
# find /var/log/ndid/ -name "*.log" -mtime +30 -delete

# ============================================================
# SECTION 9: System Health Check Script (สคริปต์ตรวจสอบระบบ)
# ============================================================

#!/bin/bash
# save as: /usr/local/bin/ndid-healthcheck.sh

echo "=== NDID System Health Check ==="
echo "Timestamp: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
echo ""

# 1. Process check
echo "[1] Process Status"
if pgrep -f ndid-highspeed-system > /dev/null; then
    echo "  Status: RUNNING (PID: $(pgrep -f ndid-highspeed-system))"
    echo "  Memory: $(ps -o rss= -p $(pgrep -f ndid-highspeed-system) | awk '{printf "%.1f MB", $1/1024}')"
    echo "  CPU: $(ps -o %cpu= -p $(pgrep -f ndid-highspeed-system))%"
else
    echo "  Status: NOT RUNNING"
fi
echo ""

# 2. Port check
echo "[2] Port Status"
for port in 8080 4433 8443; do
    if ss -tlnp | grep -q ":$port "; then
        echo "  Port $port: OPEN"
    else
        echo "  Port $port: CLOSED"
    fi
done
echo ""

# 3. Certificate check
echo "[3] Certificate Status"
if [ -f /etc/ndid/certs/server.pem ]; then
    expiry=$(openssl x509 -in /etc/ndid/certs/server.pem -noout -enddate | cut -d= -f2)
    days_left=$(( ( $(date -d "$expiry" +%s) - $(date +%s) ) / 86400 ))
    if [ $days_left -lt 30 ]; then
        echo "  WARNING: Certificate expires in $days_left days"
    else
        echo "  Certificate valid for $days_left more days"
    fi
else
    echo "  Certificate file not found"
fi
echo ""

# 4. HSM check
echo "[4] HSM Status"
if pkcs11-tool --list-slots 2>/dev/null | grep -q "Slot"; then
    echo "  HSM: DETECTED"
else
    echo "  HSM: NOT DETECTED"
fi
echo ""

# 5. Disk space
echo "[5] Disk Space"
df -h / | awk 'NR==2 {printf "  Used: %s / %s (%s)\n", $3, $2, $5}'
echo ""

# 6. Network latency to peer nodes
echo "[6] Peer Connectivity"
for peer in 10.0.1.50 10.0.1.51 10.0.1.52; do
    latency=$(ping -c 1 -W 2 $peer 2>/dev/null | tail -1 | awk -F'/' '{print $5}')
    if [ -n "$latency" ]; then
        echo "  $peer: ${latency}ms"
    else
        echo "  $peer: UNREACHABLE"
    fi
done
echo ""

echo "=== Health Check Complete ==="
