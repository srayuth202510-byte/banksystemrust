# System Debug Log - NDID Banking System
# ใช้บันทึกข้อมูลระบบและ debug session สำหรับ troubleshoot

# ============================================================
# SECTION 1: System Information (ข้อมูลระบบ)
# ============================================================

## OS & Kernel
- OS: Linux (Ubuntu 22.04 LTS / CentOS Stream 9 / RHEL 9)
- Kernel: $(uname -r)
- Architecture: $(uname -m) (x86_64 / aarch64)
- Hostname: $(hostname)
- Uptime: $(uptime -p)

## CPU
- Model: $(lscpu | grep 'Model name' | cut -d: -f2 | xargs)
- Cores: $(nproc) physical, $(nproc --all) logical
- Frequency: $(lscpu | grep 'CPU MHz' | cut -d: -f2 | xargs) MHz
- Flags: $(lscpu | grep 'Flags' | cut -d: -f2 | head -c 200)

## Memory
- Total: $(free -h | awk '/^Mem:/ {print $2}')
- Used: $(free -h | awk '/^Mem:/ {print $3}')
- Available: $(free -h | awk '/^Mem:/ {print $7}')
- Swap Total: $(free -h | awk '/^Swap:/ {print $2}')
- Swap Used: $(free -h | awk '/^Swap:/ {print $3}')

## Disk
- Root Partition: $(df -h / | awk 'NR==2 {print $2 " total, " $3 " used, " $4 " available (" $5 " used)"}')
- IO Scheduler: $(cat /sys/block/sda/queue/scheduler 2>/dev/null || echo "N/A")
- IOPS (fio): Run `fio --name=randread --ioengine=libaio --iodepth=32 --rw=randread --bs=4k --direct=1 --size=1G --numjobs=4 --runtime=60 --group_reporting`

## Network
- Primary Interface: $(ip route | grep default | awk '{print $5}' | head -1)
- IP Address: $(ip -4 addr show $(ip route | grep default | awk '{print $5}' | head -1) | grep inet | awk '{print $2}')
- DNS Servers: $(cat /etc/resolv.conf | grep nameserver | awk '{print $2}' | tr '\n' ', ')
- MTU: $(ip link show $(ip route | grep default | awk '{print $5}' | head -1) | grep mtu | awk '{print $5}')
- UDP Port Range: $(cat /proc/sys/net/ipv4/ip_local_port_range)
- QUIC Ready: $(sysctl net.ipv4.udp_mem 2>/dev/null && echo "YES" || echo "CHECK UDP CONFIG")

## Firewall / Security
- UFW Status: $(ufw status 2>/dev/null || echo "N/A")
- iptables rules: $(iptables -L -n 2>/dev/null | wc -l) rules
- SELinux: $(getenforce 2>/dev/null || echo "N/A")

# ============================================================
# SECTION 2: Rust Toolchain (เครื่องมือ Rust)
# ============================================================

## Rust Version
- rustc: $(rustc --version 2>/dev/null || echo "NOT INSTALLED")
- cargo: $(cargo --version 2>/dev/null || echo "NOT INSTALLED")
- rustup: $(rustup show 2>/dev/null | head -5 || echo "NOT INSTALLED")
- Edition: 2024 (as per AGENTS.md)

## Cargo Audit
- cargo-audit: $(cargo audit --version 2>/dev/null || echo "NOT INSTALLED - run: cargo install cargo-audit")
- cargo-vet: $(cargo vet --version 2>/dev/null || echo "NOT INSTALLED - run: cargo install cargo-vet")
- cargo-clippy: $(cargo clippy --version 2>/dev/null || echo "NOT INSTALLED")

## Installed Crates (key dependencies)
- axum: $(cargo tree -p axum 2>/dev/null | head -1 || echo "N/A")
- tokio: $(cargo tree -p tokio 2>/dev/null | head -1 || echo "N/A")
- quinn: $(cargo tree -p quinn 2>/dev/null | head -1 || echo "N/A")
- async-graphql: $(cargo tree -p async-graphql 2>/dev/null | head -1 || echo "N/A")

# ============================================================
# SECTION 3: Application Runtime (ข้อมูล Runtime ของระบบ)
# ============================================================

## Process Status
- Binary: ndid-highspeed-system
- PID: $(pgrep -f ndid-highspeed-system || echo "NOT RUNNING")
- Memory (RSS): $(ps -o rss= -p $(pgrep -f ndid-highspeed-system) 2>/dev/null | awk '{print $1/1024 " MB"}' || echo "N/A")
- CPU Usage: $(ps -o %cpu= -p $(pgrep -f ndid-highspeed-system) 2>/dev/null || echo "N/A")%
- Thread Count: $(ls /proc/$(pgrep -f ndid-highspeed-system)/task 2>/dev/null | wc -l || echo "N/A")

## Port Listening
- GraphQL Gateway: $(ss -tlnp | grep ':8080\|:443' || echo "NOT LISTENING")
- QUIC Port: $(ss -ulnp | grep ':4433\|:8443' || echo "NOT LISTENING")
- TCP Fallback: $(ss -tlpn | grep ':4433\|:8443' || echo "NOT LISTENING")

## Connection Pool
- Active QUIC connections: Check application logs
- Active TCP connections: Check application logs
- WebSocket connections: Check application logs

## HSM Status
- HSM Device: $(pkcs11-tool --list-slots 2>/dev/null || echo "NOT DETECTED - check PKCS#11 driver")
- HSM Connection: $(echo "test" | pkcs11-tool --module /usr/lib/softhsm/libsofthsm2.so --login --pin 0000 2>/dev/null && echo "OK" || echo "FAILED")

## Blockchain Node
- Substrate Node: $(systemctl status substrate-node 2>/dev/null | head -3 || echo "N/A")
- Peer Count: $(curl -s http://localhost:9933 2>/dev/null | head -1 || echo "N/A")
- Best Block: $(curl -s http://localhost:9933 2>/dev/null | tail -1 || echo "N/A")

# ============================================================
# SECTION 4: Debug Session Log (บันทึก Debug Session)
# ============================================================

# Format:
# [TIMESTAMP] [LEVEL] [MODULE] [MESSAGE]
# LEVEL: INFO, WARN, ERROR, DEBUG
# MODULE: network, blockchain, crypto, graphql, identity, system

# Example entries (append new entries at the bottom):

# 2024-01-15T10:30:00Z [INFO] [system] Application started successfully
# 2024-01-15T10:30:01Z [INFO] [network] QUIC listener bound to 0.0.0.0:4433
# 2024-01-15T10:30:01Z [INFO] [network] TCP fallback listener bound to 0.0.0.0:8443
# 2024-01-15T10:30:02Z [INFO] [graphql] GraphQL gateway ready on :8080/graphql
# 2024-01-15T10:30:05Z [WARN] [network] QUIC connection to 10.0.1.50:4433 failed, falling back to TCP
# 2024-01-15T10:30:05Z [INFO] [network] Fallback to TCP successful for 10.0.1.50:8443
# 2024-01-15T10:35:00Z [ERROR] [blockchain] Substrate node unreachable - queuing transaction
# 2024-01-15T10:35:01Z [INFO] [blockchain] Transaction queued: tx_id=abc123, queue_depth=1
# 2024-01-15T10:35:10Z [INFO] [blockchain] Substrate node recovered, flushing queue
# 2024-01-15T10:35:10Z [INFO] [blockchain] Transaction committed: tx_id=abc123, block_hash=0xdef456

